@model WebApplication1.Models.ErrorViewModel

@{
    ViewData["Title"] = "Ошибка";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="alert alert-danger">
                <h1 class="display-4">Ошибка</h1>
                <p>Произошла ошибка при обработке вашего запроса.</p>

                @if (Model.ShowRequestId)
                {
                    <p>
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </p>
                }

                <hr />
                <p class="mb-0">Пожалуйста, попробуйте позже или свяжитесь с администратором.</p>
            </div>

            <div class="mt-3">
                <a asp-action="Profile" class="btn btn-primary">Вернуться к профилю</a>
            </div>
        </div>
    </div>
</div>
